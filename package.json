{
  "name": "davidos",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "DavidOS — personal agentic command center. Local-first, mobile-first PWA.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "npm ci",
    "dev": "vite",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && node scripts/stamp-sw-version.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "npm run build && playwright test",
    "validate:seed": "node scripts/validate-seed.mjs",
    "verify": "npm run lint && npm test && npm run validate:seed && npm run build",
    "verify:full": "npm run verify && playwright test",
    "icons": "node scripts/make-icons.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
